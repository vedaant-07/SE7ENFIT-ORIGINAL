generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  ADMIN
}

enum SubscriptionStatus {
  FREE_TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanType {
  FREE_7_DAYS
  BASIC_MONTHLY
  PREMIUM_MONTHLY
  QUARTERLY
  ANNUAL
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)

  heightCm     Float?
  weightKg     Float?
  goal         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
  workoutLogs   WorkoutLog[]
  foodLogs      FoodLog[]
  progressLogs  ProgressLog[]
  challengeJoins ChallengeParticipant[]
  healthSyncRecords HealthSyncRecord[]
  dailyHealthSummaries DailyHealthSummary[]
  workoutSessions WorkoutSession[]
  pushTokens PushToken[]

  gymProfiles GymProfile[]
  gymMembers GymMember[]
  gymPayments GymPayment[]
  gymLeads GymLead[]
  gymAttendance GymAttendanceRecord[]
  gymCampaigns GymCampaign[]
  gymEquipment GymEquipment[]
  gymReviews GymReview[]
  gymReferrals GymReferral[]
  gymWorkoutPlans GymWorkoutPlan[]
  gymDietPlans GymDietPlan[]
  gymAssignedWorkouts GymAssignedWorkoutPlan[]
  gymAssignedDiets GymAssignedDietPlan[]
  gymWhatsAppMessages GymWhatsAppMessage[]
  gymEmailMessages GymEmailMessage[]
  gymStaff GymStaff[]
  gymClasses GymClass[]
  gymPlans GymMembershipPlan[]
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  planType    PlanType
  status      SubscriptionStatus @default(FREE_TRIAL)
  amountInr   Int
  startsAt    DateTime
  endsAt      DateTime
  paymentId   String?
  provider    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id              String   @id @default(cuid())
  title           String
  category        String
  muscleGroup     String?
  difficulty      String
  durationMinutes Int
  caloriesBurn    Int?
  animatedGuideUrl String?
  instructions    String? @db.Text
  isPremium       Boolean @default(false)
  createdAt       DateTime @default(now())

  logs WorkoutLog[]
}

model WorkoutLog {
  id              String   @id @default(cuid())
  userId          String
  workoutId       String?
  title           String
  durationMinutes Int
  caloriesBurned  Int?
  completedAt     DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
}

model FoodLog {
  id          String   @id @default(cuid())
  userId      String
  foodName    String
  calories    Float
  proteinGram Float
  carbsGram   Float?
  fatGram     Float?
  imageUrl    String?
  scannedByAi Boolean  @default(false)
  loggedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id        String   @id @default(cuid())
  userId    String
  weightKg  Float?
  chestCm   Float?
  waistCm   Float?
  armsCm    Float?
  notes     String?
  photoUrl  String?
  loggedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  targetValue Int
  rewardCoins Int      @default(0)
  startsAt    DateTime
  endsAt      DateTime
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())

  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  joinedAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String
  coinsNeeded Int
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
}

model HealthSyncRecord {
  id              String   @id @default(cuid())
  userId          String
  source          String   @default("health_connect")
  syncedForDate   DateTime @default(now())
  steps           Int?
  distanceMeters  Float?
  activeCalories  Float?
  totalCalories   Float?
  exerciseMinutes Int?
  weightKg        Float?
  heightCm        Float?
  rawPayload       Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncedForDate])
}

model DailyHealthSummary {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  steps           Int      @default(0)
  distanceMeters  Float    @default(0)
  activeCalories  Float    @default(0)
  totalCalories   Float    @default(0)
  exerciseMinutes Int      @default(0)
  weightKg        Float?
  heightCm        Float?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WorkoutSession {
  id               String    @id @default(cuid())
  userId           String
  workoutPlanId    String?
  title            String?
  status           String    @default("ACTIVE")
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  caloriesEstimate Float?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]

  @@index([userId, startedAt])
}

model WorkoutSet {
  id              String   @id @default(cuid())
  sessionId       String
  exerciseId      String?
  exerciseName    String?
  setNumber       Int?
  reps            Int?
  weightKg        Float?
  durationSeconds Int?
  restSeconds     Int?
  completed       Boolean  @default(true)
  createdAt       DateTime @default(now())

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GymProfile {
  id                   String   @id @default(cuid())
  ownerId              String
  gym_name             String?
  owner_name           String?
  email                String?
  mobile               String?
  address              String?  @db.Text
  city                 String?
  state                String?
  pincode              String?
  description          String?  @db.Text
  logo_url             String?
  image_url            String?
  amenities            Json?
  opening_hours        Json?
  onboarding_completed Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId])
  @@index([ownerId])
}

model GymMember {
  id             String   @id @default(cuid())
  ownerId        String
  name           String
  email          String?
  phone          String?
  status         String   @default("active")
  plan_name      String?
  join_date      DateTime?
  renewal_date   DateTime?
  amount         Float?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  attendance GymAttendanceRecord[]
  payments GymPayment[]

  @@index([ownerId])
}

model GymPayment {
  id          String   @id @default(cuid())
  ownerId     String
  memberId    String?
  amount      Float    @default(0)
  status      String   @default("paid")
  method      String?
  description String?
  paid_at     DateTime?
  due_date    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  member GymMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([memberId])
}

model GymLead {
  id             String   @id @default(cuid())
  ownerId        String
  name           String
  phone          String?
  email          String?
  source         String?
  status         String   @default("new")
  follow_up_date DateTime?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymAttendanceRecord {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String?
  date      DateTime @default(now())
  check_in  DateTime?
  check_out DateTime?
  status    String   @default("present")
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  member GymMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([memberId])
}

model GymCampaign {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?  @db.Text
  status      String   @default("active")
  start_date  DateTime?
  end_date    DateTime?
  cta_text    String?
  cta_url     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymEquipment {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  category    String?
  status      String   @default("working")
  notes       String?  @db.Text
  purchased_at DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymReview {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String?
  name      String?
  rating    Int      @default(5)
  comment   String?  @db.Text
  reply     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymReferral {
  id        String   @id @default(cuid())
  ownerId   String
  code      String?
  name      String?
  phone     String?
  status    String   @default("new")
  reward    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymWorkoutPlan {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?  @db.Text
  difficulty  String?
  status      String   @default("active")
  data        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymDietPlan {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?  @db.Text
  status      String   @default("active")
  data        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymAssignedWorkoutPlan {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String?
  title     String?
  status    String   @default("active")
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymAssignedDietPlan {
  id        String   @id @default(cuid())
  ownerId   String
  memberId  String?
  title     String?
  status    String   @default("active")
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymWhatsAppMessage {
  id        String   @id @default(cuid())
  ownerId   String
  to        String?
  message   String?  @db.Text
  status    String   @default("queued")
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymEmailMessage {
  id        String   @id @default(cuid())
  ownerId   String
  to        String?
  subject   String?
  message   String?  @db.Text
  status    String   @default("queued")
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymStaff {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  phone     String?
  email     String?
  role      String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymClass {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  trainer   String?
  schedule  String?
  capacity  Int?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model GymMembershipPlan {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  amount      Float    @default(0)
  durationDays Int?
  description String?  @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}
